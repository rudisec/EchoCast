<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp">

        <!-- Enable Switch Section - Gray Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/enable_playback"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.1" />

                <!-- White Box Inside Gray Box - Redesigned -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">

                        <!-- Title -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_playback"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:layout_marginBottom="8dp" />

                        <!-- Description -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/enable_playback_description"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center"
                            android:layout_marginBottom="24dp" />

                        <!-- Large Switch -->
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchEnable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:scaleX="1.3"
                            android:scaleY="1.3" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Play Mode Section - Gray Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/play_mode"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.1" />

                <!-- White Box Inside Gray Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:id="@+id/playModeGroupContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnModeSingle"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/play_mode_single"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/surface"
                            android:textColor="@color/on_surface"
                            app:cornerRadius="12dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@android:color/transparent"
                            app:elevation="0dp"
                            android:layout_marginEnd="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnModeLoop"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/play_mode_loop"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/surface"
                            android:textColor="@color/on_surface"
                            app:cornerRadius="12dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@android:color/transparent"
                            app:elevation="0dp"
                            android:layout_marginEnd="4dp"
                            android:layout_marginStart="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnModeShuffle"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/play_mode_shuffle"
                            android:textSize="12sp"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/surface"
                            android:textColor="@color/on_surface"
                            app:cornerRadius="12dp"
                            app:strokeWidth="0dp"
                            app:strokeColor="@android:color/transparent"
                            app:elevation="0dp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Shuffle Controls (only visible when Shuffle mode is selected) -->
                <LinearLayout
                    android:id="@+id/layoutShuffleControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShufflePlayPause"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/play_resume"
                        android:textColor="@color/on_primary"
                        android:backgroundTint="@color/primary"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconTint="@color/on_primary"
                        app:cornerRadius="12dp"
                        app:elevation="0dp"
                        android:layout_marginEnd="12dp" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkboxShuffleLoop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shuffle_loop"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Soundboard Section - No boxes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/audio_playlist"
                android:textAllCaps="true"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/soundboard_subtitle"
                android:textSize="11sp"
                android:textColor="@color/on_surface_variant" />

            <!-- Playlist Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical|center_horizontal"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fabAddAudio"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_audio"
                    android:textColor="@color/on_primary"
                    android:backgroundTint="@color/primary"
                    android:textAllCaps="false"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconTint="@color/on_primary"
                    app:cornerRadius="12dp"
                    app:elevation="0dp" />

                <LinearLayout
                    android:id="@+id/layoutSelectionActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditName"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edit_name"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/black"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconTint="@android:color/white"
                        app:cornerRadius="12dp"
                        app:elevation="0dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDelete"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/delete"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#D32F2F"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconTint="@android:color/white"
                        app:cornerRadius="12dp"
                        app:elevation="0dp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewPlaylist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="0dp"
                tools:listitem="@layout/item_audio" />

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/add_first_audio"
                android:textColor="@color/on_surface_variant"
                android:visibility="gone" />

        </LinearLayout>

        <!-- About Section - Gray Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="About"
                    android:textAllCaps="true"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.1" />

                <!-- White Box Inside Gray Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EchoCast"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Version 2.0.0"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
