#!/sbin/sh

#################
# Initialization
#################

umask 022

# echo before loading util_functions
ui_print() { echo "$1"; }

require_new_magisk() {
  ui_print "*******************************"
  ui_print " Please install Magisk v20.4+! "
  ui_print "*******************************"
  exit 1
}

#########################
# Load util_functions.sh
#########################

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

[ -f /data/adb/magisk/util_functions.sh ] || require_new_magisk
. /data/adb/magisk/util_functions.sh
[ $MAGISK_VER_CODE -lt 20400 ] && require_new_magisk

ui_print " "
ui_print "  ========================================"
ui_print "  |          E C H O C A S T            |"
ui_print "  |  Your soundboard, in every call.    |"
ui_print "  ========================================"
ui_print " "
ui_print "  >> Installing EchoCast..."
ui_print " "

# Suppress Magisk's default "EchoCast by rudisec" and "Powered by Magisk" output
ui_print() { :; }
install_module
ui_print() { echo "$1"; }

ui_print " "
ui_print "  [*] EchoCast installed successfully!"
ui_print "  [*] Reboot to activate."
ui_print " "
exit 0
